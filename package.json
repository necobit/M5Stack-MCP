{
  "name": "m5stack-mcp",
  "version": "0.1.0",
  "description": "MCP server for M5Stack product lineup — search, compatibility check, and configuration advice for prototyping",
  "type": "module",
  "license": "MIT",
  "author": "necobit",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/necobit/M5Stack-MCP.git"
  },
  "bin": {
    "m5stack-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "data"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "update-data": "tsx scripts/update-data.ts",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "test": "vitest run"
  },
  "keywords": [
    "mcp",
    "m5stack",
    "model-context-protocol",
    "iot",
    "prototyping"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
